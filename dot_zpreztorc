#
# General
#

zstyle ':prezto:*:*' color 'yes'

# Set the Prezto modules to load (browse modules).
# The order matters.
zstyle ':prezto:load' pmodule \
  'environment' \
  'terminal' \
  'editor' \
  'history' \
  'directory' \
  'spectrum' \
  'utility' \
  'completion' \
  'git' \
  'docker' \
  'tmux' \
  'ssh' \
  'autosuggestions' \
  'syntax-highlighting' \
  'history-substring-search'

# Prompt disabled - using custom Kali prompt in .zshrc
# zstyle ':prezto:module:prompt' theme 'pure'

#
# Editor
#

# Set the key mapping style to 'emacs' or 'vi'.
zstyle ':prezto:module:editor' key-bindings 'emacs'

#
# History
#

# Set the maximum number of events stored in the internal history list.
zstyle ':prezto:module:history' histsize 50000

# Set the maximum number of history events to save in the history file.
zstyle ':prezto:module:history' savehist 50000

#
# History Substring Search
#

# Enable search case-sensitivity.
# zstyle ':prezto:module:history-substring-search' case-sensitive 'yes'

# Enable search for fuzzy matches.
zstyle ':prezto:module:history-substring-search' fuzzy 'yes'

#
# SSH
#

# Set the SSH identities to load into the agent.
# zstyle ':prezto:module:ssh:load' identities 'id_rsa' 'id_ed25519'

#
# Syntax Highlighting
#

# Set syntax highlighters.
zstyle ':prezto:module:syntax-highlighting' highlighters \
  'main' \
  'brackets' \
  'cursor'

# Highlight rm -rf in red
zstyle ':prezto:module:syntax-highlighting' pattern \
  'rm*-rf*' 'fg=white,bold,bg=red'

#
# Terminal
#

# Auto set the tab and window titles.
zstyle ':prezto:module:terminal' auto-title 'yes'

#
# Utility
#

# Enable safe options (prompt before overwriting).
zstyle ':prezto:module:utility' safe-ops 'yes'
