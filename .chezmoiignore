# =============================================================================
# Chezmoi Ignore Patterns
# =============================================================================
# Files matching these patterns will NOT be managed by chezmoi.
# Organized by category for maintainability.
# =============================================================================

# --- Build artifacts & caches -----------------------------------------------
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/venv/
**/.venv/
**/env/
**/node_modules/
**/.npm/
**/.cache/
**/dist/
**/build/
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# --- Large binaries & AI model weights --------------------------------------
**/*.bin
**/*.safetensors
**/*.gguf
**/*.onnx
**/*.h5
**/*.pkl
**/*.pt
**/*.pth
**/*.ckpt
**/*.mlmodel
**/*.pb

# --- Git internals ----------------------------------------------------------
**/.git/
**/.gitattributes
**/.gitmodules

# --- Docker & containers ----------------------------------------------------
**/volumes/
**/_data/
**/.docker/

# --- IDE & editor runtime ---------------------------------------------------
**/.idea/
**/.vscode/settings.json
**/.vscode/sync/
**/.vscode/cstate*
**/.vscode/db-*
**/*.code-workspace

# --- OS junk ----------------------------------------------------------------
**/.DS_Store
**/Thumbs.db
**/desktop.ini
**/.AppleDouble
**/._*

# --- Logs & temp files ------------------------------------------------------
**/*.log
**/logs/
**/*.tmp
**/*.swp
**/*.swo
**/*~
**/*.bak

# --- Terraform & IaC state --------------------------------------------------
**/.terraform/
**/terraform.tfstate
**/terraform.tfstate.backup
**/.terraform.lock.hcl

# --- Chezmoi internals ------------------------------------------------------
**/chezmoistate.boltdb

# --- HuggingFace / ML caches ------------------------------------------------
**/.cache/huggingface/

# --- AI model directories (managed separately) ------------------------------
**/models/
**/weights/

# --- Runtime-generated data -------------------------------------------------
dotfiles-ai/backups/
dotfiles-ai/logs/
dotfiles-ai/validation_report.json
dotfiles-ai/system_config.json

# --- Secret files (use age encryption or password manager) -------------------
# NOTE: SSH keys are encrypted with age and stored as encrypted_*.
# Raw unencrypted secret files are still ignored.
**/*.pem
**/*.key
**/id_rsa
**/id_ecdsa
**/id_dsa
**/.bw_credentials
**/.bw_master_password
**/.env
**/.env.*
**/secrets.json
**/auth.json
**/api_keys.*
**/credentials.*
key.txt.age

# --- Cline / Claude Code runtime data ---------------------------------------
**/.cline/data/sessions/
**/.cline/data/tasks/
**/.cline/data/workspaces/
**/.cline/data/globalState.json
**/.cline/data/state/
**/.cline/data/cache/
**/.cline/data/settings/
**/.cline/kanban/
**/.cline/data/sessions.db*
**/.cline/ide/*.lock

# --- Codex runtime data -----------------------------------------------------
**/.codex/logs_*.sqlite*
**/.codex/state_*.sqlite
**/.codex/auth.json
**/.codex/.tmp/

# --- KiloCode runtime data --------------------------------------------------
**/.kilocode/node_modules/
**/.kilocode/bun.lock
**/.kilocode/package-lock.json

# --- OpenCode runtime data --------------------------------------------------
**/.config/opencode/node_modules/
**/.config/opencode/bun.lock
**/.config/opencode/package-lock.json

# --- Windsurf / Codeium runtime data ----------------------------------------
**/.codeium/windsurf/memories/*.pb
**/.codeium/windsurf/installation_id
**/.codeium/windsurf/native_storage_migrations.lock
**/.codeium/windsurf/code_tracker/

# --- Cursor runtime data ----------------------------------------------------
**/.cursor/skills/**/__pycache__/

# --- Placeholder files (empty or auto-generated) ----------------------------
**/agents.md

# --- Epstein project data (too large, separate data repo) -------------------
epstein-data/

