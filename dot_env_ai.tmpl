{{- $openrouter_key := promptStringOnce . "openrouter_key" "OpenRouter API key" -}}
{{- $gemini_key := promptStringOnce . "gemini_key" "Gemini API key" -}}

# AI API Keys
export OPENROUTER_API_KEY="{{ $openrouter_key }}"
export GEMINI_API_KEY="{{ $gemini_key }}"

# Letta server
export LETTA_SERVER_URL="http://localhost:8283"

# CBW RAG
export CBW_RAG_DATABASE="postgresql://cbwinslow:{{ .db_password | default "" }}@localhost:5432/cbw_rag"
export CBW_RAG_OLLAMA_URL="http://localhost:11434"
export CBW_RAG_EMBEDDING_MODEL="nomic-embed-text"

# Ollama
export OLLAMA_HOST="localhost:11434"
