root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,jsonc,json5,yml,yaml,toml}]
indent_size = 2

[*.{sh,bash,zsh}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[Dockerfile*]
indent_size = 4
