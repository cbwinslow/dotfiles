{{- $mem0_key := promptStringOnce . "mem0_key" "Mem0 API key" -}}
{{- $taskade_key := promptStringOnce . "taskade_key" "Taskade API key" -}}
{{- $contextstream_key := promptStringOnce . "contextstream_key" "ContextStream API key" -}}

{
  "mcpServers": {
    "github.com/mem0ai/mem0-mcp": {
      "command": "python",
      "args": [
        "-m",
        "mem0_mcp_server.server"
      ],
      "env": {
        "MEM0_API_KEY": {{ $mem0_key | quote }},
        "MEM0_DEFAULT_USER_ID": "mem0-mcp"
      }
    },
    "github.com/financialdatanet/fdnpy": {
      "command": "node",
      "args": [
        "fdnpy-server/index.js"
      ],
      "env": {
        "FDN_API_KEY": "{{ .fdn_key | default "" }}"
      },
      "autoApprove": [
        "get_stock_prices",
        "get_company_info"
      ]
    },
    "financial-datasets": {
      "url": "https://mcp.financialdatasets.ai/",
      "env": {
        "FD_API_KEY": "{{ .fd_api_key | default "" }}"
      }
    },
    "github.com/puppeteer/web-access": {
      "command": "node",
      "args": [
        "web-access-server/index.js"
      ]
    },
    "github.com/taskade/mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@taskade/mcp-server"
      ],
      "env": {
        "TASKADE_API_KEY": {{ $taskade_key | quote }}
      }
    },
    "github.com/microsoft/playwright-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser=firefox",
        "--headless"
      ],
      "disabled": false,
      "autoApprove": [
        "browser_navigate"
      ]
    },
    "github.com/contextstream/mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@contextstream/mcp-server"
      ],
      "env": {
        "CONTEXTSTREAM_API_KEY": {{ $contextstream_key | quote }}
      },
      "disabled": false,
      "autoApprove": []
    },
    "github.com/googleapis/genai-toolbox": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server",
        "--tools-file",
        "tools.yaml"
      ],
      "disabled": false,
      "autoApprove": []
    },
    "github.com/universal-tool-calling-protocol/code-mode": {
      "command": "npx",
      "args": [
        "@utcp/code-mode-mcp"
      ],
      "env": {
        "UTCP_CONFIG_FILE": ".utcp_config.json"
      },
      "disabled": false,
      "autoApprove": []
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ],
      "env": {
        "LOCALAPPDATA": "${LOCALAPPDATA}",
        "ProgramData": "${ProgramData}",
        "ProgramFiles": "${ProgramFiles}"
      }
    }
  }
}
